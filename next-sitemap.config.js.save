import dotenv from "dotenv";
dotenv.config({ path: ".env.local" });

import clientPromise from "./lib/mongodb.js";

export default {
  siteUrl: "https://web.malidag.com",
  generateRobotsTxt: true,
  sitemapSize: 5000,

  async additionalPaths() {
    const client = await clientPromise;
    const db = client.db(process.env.MONGODB_DB);
    const products = await db.collection("products").find({}).toArray();

    // Dynamic product pages
    const productPaths = products.map((item) => ({
      loc: `/product/${item.itemId}`,
      changefreq: "daily",
      priority: 0.8,
    }));

    // Static important pages
    const staticPaths = [
      { loc: "/about", changefreq: "monthly", priority: 0.7 },
      { loc: "/review", changefreq: "weekly", priority: 0.7 },
      { loc: "/contact", changefreq: "monthly", priority: 0.6 },
      { loc: "/fashionPage", changefreq: "weekly", priority: 0.6 },
      { loc: "/electronic", changefreq: "weekly", priority: 0.6 },
      // 👆 Add any other core categories you want highlighted in Google
    ];

    return [...productPaths, ...staticPaths];
  },
};
